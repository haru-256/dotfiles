command = /opt/homebrew/bin/fish -l

# theme = "Dracula"
# theme = "Aura"
theme = Catppuccin Latte

# background-opacity = 0.95
# background-blur-radius = 20
# background-blur = true

# font-family = "Inconsolata Nerd Font"
# font-size = 17
# font-family = "HackGen35 Console NF"
