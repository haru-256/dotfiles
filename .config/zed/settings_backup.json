// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "agent_servers": {
    "github-copilot": {
      "type": "registry"
    }
  },
  "always_treat_brackets_as_autoclosed": true,
  "colorize_brackets": true,
  "edit_predictions": {
    "provider": "copilot",
    "mode": "eager",
  },
  "inlay_hints": {
    "show_background": false,
    "enabled": true,
  },
  "tabs": {
    "file_icons": true,
  },
  "agent_buffer_font_size": 16.5,
  "agent_ui_font_size": 17.0,
  "agent": {
    "profiles": {
      "ask": {
        "name": "Ask",
        "tools": {},
        "enable_all_context_servers": false,
        "context_servers": {}
      }
    },
    "favorite_models": [
      {
        "provider": "copilot_chat",
        "model": "claude-sonnet-4.5"
      },
      {
        "provider": "copilot_chat",
        "model": "claude-haiku-4.5"
      },
      {
        "provider": "copilot_chat",
        "model": "gemini-3-flash-preview"
      },
      {
        "provider": "copilot_chat",
        "model": "gpt-5.3-codex"
      }
    ],
    "always_allow_tool_actions": true,
    "inline_assistant_model": {
      "provider": "copilot_chat",
      "model": "gemini-3-flash-preview",
    },
    "use_modifier_to_send": true,
    "default_profile": "write",
    "default_model": {
      "provider": "copilot_chat",
      "model": "claude-haiku-4.5",
    },
    "model_parameters": [],
  },
  "context_servers": {
    "terraform-context-server": {
      "enabled": true,
      "settings": {}
    },
    "mcp-server-context7": {
      "enabled": true,
      "settings": {
        "context7_api_key": "ctx7sk-eefd288e-57ee-4cd6-8d21-acdfd4e2bb16",
      },
    },
  },
  "indent_guides": {
    "background_coloring": "disabled",
    "coloring": "indent_aware",
  },
  "ui_font_family": ".ZedSans",
  "icon_theme": "Catppuccin Mocha",
  "vim_mode": true,
  "terminal": {
    "shell": {
      "program": "/opt/homebrew/bin/fish",
    },
    "env": {
      "Q_NEW_SESSION": "\"1\"",
      "FIG_NEW_SESSION": "\"1\"",
      "CW_NEW_SESSION": "\"1\"",
    },
    "font_size": 16.5,
    "font_family": "Inconsolata Nerd Font",
  },
  "project_panel": {
    "hide_gitignore": false,
    "dock": "right",
    "auto_fold_dirs": false,
  },
  "base_keymap": "VSCode",
  "tab_bar": {
    "show": false,
  },
  "sticky_scroll": {
    "enabled": true,
  },
  "minimap": {
    "current_line_highlight": "all",
    "thumb_border": "left_open",
    "show": "auto",
    "thumb": "always",
  },
  "cursor_blink": false,
  "autosave": "on_focus_change",
  "buffer_font_family": "MyricaM M",
  "file_types": {
    "tailwindcss": ["*.css"],
    "nginx": ["nginx.conf"],
    "json": ["*.json.golden"],
    "ini": ["*.cnf"],
  },
  "show_edit_predictions": true,
  "ensure_final_newline_on_save": true,
  "soft_wrap": "editor_width",
  "ui_font_size": 17.0,
  "buffer_font_size": 16.5,
  "theme": "Catppuccin Mocha",
}
