  "permission": {
    // まずすべてを許可
    "edit": "allow",
    "read": "allow",
    "bash": {
      "*": "allow",
      "rm -rf *": "deny", // 破壊的コマンドは禁止
      "sudo *": "ask" // sudo系は都度確認
    },
    "external_directory": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "question": "allow",
    "codesearch": "allow",
    "skill": "allow",
    "todowrite": "allow",
    "grep": "allow",
    "lsp": "allow",
    "task": "allow",
    "glob": "allow",
    "list": "allow"
  },
  "mcp": {
    // ドキュメント検索
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    }
  },
  "plugin": [
    "superpowers@git+https://github.com/obra/superpowers.git"
  ]
}
