{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "orchestrator",
  "lsp": true,
  // エージェント別のツール制御
  "agent": {
    "build": { "disable": true },
    "plan": { "disable": true },
    "general": { "disable": true },
    "explore": { "disable": true },
    "scout": { "disable": true },
    "orchestrator": {
      "description": "Primary orchestrator agent. Receives user requests, routes to specialists, writes plans/ADRs/README/docs, adjudicates reviewer findings, and handles failure loops. Does not edit source code or tests.",
      "mode": "primary",
      "model": "openai/gpt-5.5",
      "reasoningEffort": "medium",
      // "model": "opencode-go/deepseek-v4-pro",
      // "reasoningEffort": "max",
      "textVerbosity": "low",
      "temperature": 0.1,
      "prompt": "{file:~/.config/opencode/prompts/orchestrator.md}",
      "permission": {
        "edit": "allow",
        "read": "allow",
        "bash": {
          "*": "allow",
          "rm -rf *": "deny",
          "sudo *": "ask"
        },
        "external_directory": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "question": "allow",
        "codesearch": "allow",
        "skill": "allow",
        "todowrite": "allow",
        "grep": "allow",
        "lsp": "allow",
        "task": {
          "*": "deny",
          "implementer": "allow",
          "explorer": "allow",
          "reviewer": "allow",
          "oracle": "allow"
        },
        "glob": "allow",
        "list": "allow"
      }
    },
    "implementer": {
      "description": "Implementation subagent. Makes scoped code changes, runs checks, fixes failures, and reports compact results.",
      "mode": "all",
      "model": "opencode-go/kimi-k2.7-code",
      "temperature": 0.1,
      "prompt": "{file:~/.config/opencode/prompts/implementer.md}",
      "permission": {
        "edit": "allow",
        "read": "allow",
        "bash": {
          "*": "allow",
          "rm -rf *": "deny",
          "sudo *": "ask"
        },
        "external_directory": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "question": "allow",
        "codesearch": "allow",
        "skill": "allow",
        "todowrite": "allow",
        "grep": "allow",
        "lsp": "allow",
        "task": "deny",
        "glob": "allow",
        "list": "allow"
      }
    },
    "explorer": {
      "description": "Read-only deep repository exploration subagent. Finds relevant files, dependencies, data/control flow, and likely impact radius. Returns compact reports.",
      "mode": "all",
      "model": "opencode-go/deepseek-v4-pro",
      "reasoningEffort": "max",
      "temperature": 0.1,
      "prompt": "{file:~/.config/opencode/prompts/explorer.md}",
      "permission": {
        "edit": "deny",
        "read": "allow",
        "bash": {
          "*": "allow",
          "rm -rf *": "deny",
          "sudo *": "ask"
        },
        "external_directory": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "question": "allow",
        "codesearch": "allow",
        "skill": "allow",
        "todowrite": "allow",
        "grep": "allow",
        "lsp": "allow",
        "task": "deny",
        "glob": "allow",
        "list": "allow"
      }
    },
    "reviewer": {
      "description": "Read-only multi-artifact review subagent. Reviews plan, adr, readme, docs, or implementation. Checks goal fit, correctness, security, tests, and maintainability.",
      "mode": "all",
      // "model": "opencode-go/minimax-m3",
      "model": "opencode-go/glm-5.2",
      "reasoningEffort": "high",
      "temperature": 0.1,
      "prompt": "{file:~/.config/opencode/prompts/reviewer.md}",
      "permission": {
        "edit": "deny",
        "read": "allow",
        "bash": {
          "*": "allow",
          "rm -rf *": "deny",
          "sudo *": "ask"
        },
        "external_directory": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "question": "allow",
        "codesearch": "allow",
        "skill": "allow",
        "todowrite": "allow",
        "grep": "allow",
        "lsp": "allow",
        "task": "deny",
        "glob": "allow",
        "list": "allow"
      }
    },
    "oracle": {
      "description": "Hidden high-context decision-consistency consultation subagent. Diagnoses blocked tasks, detects drift, protects inherited constraints, and returns a compact decision. It never edits files.",
      "mode": "subagent",
      "model": "openai/gpt-5.5",
      "reasoningEffort": "xhigh",
      "textVerbosity": "low",
      "temperature": 0.1,
      "prompt": "{file:~/.config/opencode/prompts/oracle.md}",
      "permission": {
        "edit": "deny",
        "read": "allow",
        "bash": {
          "*": "allow",
          "rm -rf *": "deny",
          "sudo *": "ask"
        },
        "external_directory": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "question": "allow",
        "codesearch": "allow",
        "skill": "allow",
        "todowrite": "allow",
        "grep": "allow",
        "lsp": "allow",
        "task": {
          "*": "deny",
          "explorer": "allow",
        },
        "glob": "allow",
        "list": "allow"
      }
    }
  },
  "permission": {
    // まずすべてを許可
    "edit": "allow",
    "read": "allow",
    "bash": {
      "*": "allow",
      "rm -rf *": "deny", // 破壊的コマンドは禁止
      "sudo *": "ask" // sudo系は都度確認
    },
    "external_directory": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "question": "allow",
    "codesearch": "allow",
    "skill": "allow",
    "todowrite": "allow",
    "grep": "allow",
    "lsp": "allow",
    "task": "allow",
    "glob": "allow",
    "list": "allow"
  },
  "mcp": {
    // ドキュメント検索
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    }
  },
  "plugin": [
    "superpowers@git+https://github.com/obra/superpowers.git"
  ]
}
